{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eclipse-mac.local/schemas/job.schema.json",
  "title": "Eclipse Mac Job Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "protocol_version",
    "device_id",
    "kind",
    "risk",
    "input",
    "expires_at",
    "idempotency_key"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^job_[a-z0-9_-]+$"
    },
    "protocol_version": {
      "const": "0.1"
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": [
        "context.get_active_window",
        "context.capture_window",
        "notification.show",
        "ui.set_text",
        "ui.press_key",
        "ui.click_element"
      ]
    },
    "risk": {
      "enum": [
        "read",
        "reversible",
        "consequential"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "body": {
          "type": "string",
          "maxLength": 1000
        },
        "key": {
          "enum": [
            "escape",
            "return",
            "enter",
            "tab",
            "space",
            "arrow_left",
            "arrow_right",
            "arrow_up",
            "arrow_down"
          ]
        },
        "modifiers": {
          "type": "array",
          "items": {
            "enum": [
              "command",
              "option",
              "control",
              "shift"
            ]
          },
          "uniqueItems": true,
          "maxItems": 4
        },
        "element_role": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "element_label": {
          "type": "string",
          "maxLength": 400
        }
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^idem_[a-z0-9_-]+$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "enum": [
              "context.get_active_window",
              "context.capture_window"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "risk": {
            "const": "read"
          },
          "input": {
            "maxProperties": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "notification.show"
          }
        }
      },
      "then": {
        "properties": {
          "risk": {
            "const": "reversible"
          },
          "input": {
            "required": [
              "title"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "ui.set_text"
          }
        }
      },
      "then": {
        "properties": {
          "risk": {
            "const": "reversible"
          },
          "input": {
            "required": [
              "text"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "ui.press_key"
          }
        }
      },
      "then": {
        "properties": {
          "risk": {
            "const": "reversible"
          },
          "input": {
            "required": [
              "key"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "ui.click_element"
          }
        }
      },
      "then": {
        "properties": {
          "risk": {
            "const": "consequential"
          },
          "input": {
            "required": [
              "element_role"
            ]
          }
        }
      }
    }
  ]
}
