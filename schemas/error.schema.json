  "$id": "https://eclipse-mac.local/schemas/error.schema.json",
  "title": "Eclipse Mac Error Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code",
    "message"
  ],
  "properties": {
    "code": {
      "type": "string",
