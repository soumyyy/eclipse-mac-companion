{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eclipse-mac.local/schemas/result.schema.json",
  "title": "Eclipse Mac Job Result Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "protocol_version",
    "device_id",
    "status",
    "completed_at",
    "idempotency_key"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^job_[a-z0-9_-]+$"
    },
    "protocol_version": {
      "const": "0.1"
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "succeeded",
        "failed",
        "rejected",
        "expired",
        "pending_approval"
      ]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "context": {
          "type": "object"
        },
        "approval": {
          "$ref": "approval.schema.json"
        },
        "automation_approval": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "approval_id",
            "action_id",
            "kind",
            "risk",
            "summary",
            "expires_at"
          ],
          "properties": {
            "approval_id": {
              "type": "string",
              "pattern": "^appr_[a-z0-9_-]+$"
            },
            "action_id": {
              "type": "string",
              "pattern": "^act_[a-z0-9_-]+$"
            },
            "kind": {
              "enum": [
                "ui.press_key",
                "ui.click_element"
              ]
            },
            "risk": {
              "enum": [
                "reversible",
                "consequential"
              ]
            },
            "summary": {
              "type": "string"
            },
            "target_app": {
              "type": [
                "object",
                "null"
              ]
            },
            "target_window": {
              "type": [
                "object",
                "null"
              ]
            },
            "expires_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "action_result": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action_id",
            "snapshot_id",
            "completed_at",
            "characters_written"
          ],
          "properties": {
            "action_id": {
              "type": "string",
              "pattern": "^act_[a-z0-9_-]+$"
            },
            "snapshot_id": {
              "type": "string",
              "pattern": "^ctx_[a-z0-9_-]+$"
            },
            "completed_at": {
              "type": "string",
              "format": "date-time"
            },
            "characters_written": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "capture": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "capture_id",
            "snapshot_id",
            "window_id",
            "captured_at",
            "pixel_width",
            "pixel_height"
          ],
          "properties": {
            "capture_id": {
              "type": "string",
              "pattern": "^cap_[a-z0-9_-]+$"
            },
            "snapshot_id": {
              "type": "string",
              "pattern": "^ctx_[a-z0-9_-]+$"
            },
            "window_id": {
              "type": "integer"
            },
            "captured_at": {
              "type": "string",
              "format": "date-time"
            },
            "pixel_width": {
              "type": "integer",
              "minimum": 1
            },
            "pixel_height": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "notification": {
          "type": "object"
        },
        "key_press": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action_id",
            "key",
            "modifiers",
            "completed_at"
          ],
          "properties": {
            "action_id": {
              "type": "string",
              "pattern": "^act_[a-z0-9_-]+$"
            },
            "key": {
              "type": "string"
            },
            "modifiers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "completed_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "click": {
          "type": "object"
        }
      }
    },
    "error": {
      "$ref": "error.schema.json"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^idem_[a-z0-9_-]+$"
    }
  }
}
