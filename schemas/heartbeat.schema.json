{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eclipse-mac.local/schemas/heartbeat.schema.json",
  "title": "Eclipse Mac Heartbeat",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "device_id",
    "sent_at",
    "capabilities"
  ],
  "properties": {
    "protocol_version": {
      "const": "0.1"
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "context.get_active_window",
          "context.capture_window",
          "notification.show",
          "ui.set_text",
          "ui.press_key",
          "ui.click_element"
        ]
      },
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "online",
        "idle",
        "polling",
        "waiting_for_approval"
      ]
    },
    "app_version": {
      "type": "string"
    },
    "pending_job_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "outbox_count": {
      "type": "integer",
      "minimum": 0
    },
    "bridge_status": {
      "type": "string"
    }
  }
}
